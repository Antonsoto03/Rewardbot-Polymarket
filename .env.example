# Copia este archivo a `.env` y rellena los valores reales.
# El `.env` real está ignorado por .gitignore.

# Polymarket CLOB credentials (L2)
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=

# Wallet (firma de órdenes)
PRIVATE_KEY=
FUNDER_ADDRESS=

# Configuración de cadena
POLY_BASE_URL=https://clob.polymarket.com
CHAIN_ID=137
SIGNATURE_TYPE=2

# Relayer (si aplica)
RELAYER_API_KEY=
RELAYER_API_KEY_ADDRESS=
